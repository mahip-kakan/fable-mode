<mxfile host="app.diagrams.net" modified="2026-06-21T12:00:00.000Z" agent="Fable Mode" version="22.1.0" type="device">
  <diagram id="fable-loop" name="Fable Loop">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="620" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="The Fable Loop" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=26;fontStyle=1;fontColor=#312E81;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="300" y="24" width="600" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Every stage ends with a Proof Block — evidence that can fail" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;fontColor=#4F46E5;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="250" y="58" width="700" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="s1" value="&lt;b&gt;1 — Stage map&lt;/b&gt;&lt;br&gt;&lt;br&gt;Numbered stages&lt;br&gt;Expected outputs&lt;br&gt;Done-when criteria&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Before any edits&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF2FF;strokeColor=#4F46E5;strokeWidth=2;arcSize=10;fontSize=13;fontColor=#1E1B4B;fontFamily=Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="220" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="s2" value="&lt;b&gt;2 — Delegate&lt;/b&gt;&lt;br&gt;&lt;br&gt;Parallel subagents&lt;br&gt;when work is independent&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;One level deep&lt;br&gt;Merge at host&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F9FF;strokeColor=#0EA5E9;strokeWidth=2;arcSize=10;fontSize=13;fontColor=#0C4A6E;fontFamily=Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="320" y="120" width="220" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="&lt;b&gt;3 — Proof check&lt;/b&gt;&lt;br&gt;&lt;br&gt;Tests, grep, diff&lt;br&gt;Sources actually read&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;No &amp;quot;looks correct&amp;quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;strokeWidth=2;arcSize=10;fontSize=13;fontColor=#4C1D95;fontFamily=Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="580" y="120" width="220" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="s4" value="&lt;b&gt;4 — Delivery review&lt;/b&gt;&lt;br&gt;&lt;br&gt;Skeptical read-through&lt;br&gt;Fix or flag real issues&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Confirm before flagging&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;strokeWidth=2;arcSize=10;fontSize=13;fontColor=#064E3B;fontFamily=Helvetica;align=center;" vertex="1" parent="1">
          <mxGeometry x="840" y="120" width="220" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="a12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748B;strokeWidth=2;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748B;strokeWidth=2;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748B;strokeWidth=2;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="proof-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#7C3AED;strokeWidth=2;dashed=1;dashPattern=8 8;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="180" y="320" width="840" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="proof-title" value="Proof Block (required at every stage)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#6D28D9;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="200" y="332" width="320" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="proof-code" value="Proof N — [Stage name]: PASS | FAIL | UNVERIFIED&#xa;Check:   [test, grep, query, file read, diff]&#xa;Command: [exact command or tool call]&#xa;Evidence: [exit code, assertion, line count, URL, diff hunk]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#C4B5FD;fontSize=12;fontFamily=Courier New;align=left;spacingLeft=12;spacingTop=8;fontColor=#312E81;" vertex="1" parent="1">
          <mxGeometry x="200" y="364" width="520" height="132" as="geometry"/>
        </mxCell>
        <mxCell id="proof-rules" value="&lt;b&gt;Acceptable&lt;/b&gt;&lt;br&gt;• Test exit codes&lt;br&gt;• Grep / diff output&lt;br&gt;• Sources actually read&lt;br&gt;&lt;br&gt;&lt;b&gt;Not acceptable&lt;/b&gt;&lt;br&gt;• &amp;quot;looks correct&amp;quot;&lt;br&gt;• &amp;quot;should pass&amp;quot;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;fontColor=#475569;fontFamily=Helvetica;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="740" y="364" width="260" height="132" as="geometry"/>
        </mxCell>
        <mxCell id="loop-back" value="If stage N invalidates stage M → re-run M's proof" style="text;html=1;strokeColor=none;fillColor=#FFFBEB;align=center;verticalAlign=middle;fontSize=12;fontColor=#92400E;fontFamily=Helvetica;rounded=1;strokeColor=#F59E0B;" vertex="1" parent="1">
          <mxGeometry x="360" y="540" width="480" height="32" as="geometry"/>
        </mxCell>
